name: "::run_drfuzz_mem_trace:0.1"
description: "Run HybriDIFT without traces"

filesets:
  files_dv:
    files:
      - ../milesan/dv/dpi/common_functions.cc
      - ../milesan/dv/dpi/elfloader.cc
      - ../milesan/dv/dpi/taintloader.cc
      - ../milesan/dv/testbench.h : {is_include_file: true}
      - ../milesan/dv/ticks.h : {is_include_file: true}
      - ../milesan/dv/toplevel.cc
    file_type: cppSource

  files_rtl:
    files:
      - ../milesan/cpu_cfig.h: {is_include_file: true}
      - ../milesan/sysmap.h: {is_include_file: true}
      - ../milesan/milesanparams.h : {is_include_file: true}
      - ../milesan/generated/out/drfuzz_mem.sv
      - ../milesan/src/util/ift_axi_to_mem.sv
      - ../milesan/src/util/ift_milesan_sram_mem.sv
      - ../milesan/tmp/all_memshade.v
      - ../milesan/src/openc910_tiny_soc_taints.sv
      - ../milesan/src/util/my_fpga_ram.v
      - ../milesan/dv/sv/clk_rst_gen.sv
    file_type: systemVerilogSource


targets:
  default:
    default_tool: verilator
    filesets:
      - files_rtl
      - files_dv
    toplevel: openc910_tiny_soc
    tools:
      verilator:
        mode: cc
        verilator_options:
          - '-CFLAGS "-std=c++14 -Wall -O0"'
          - '-LDFLAGS "-pthread -lutil"'
          - '--trace'
          - '--trace-max-array 2048'
          - '--build-jobs 64'
          - "--timing"
          - "-Wall"
          - "-Wno-fatal"
          - "-Wno-CMPCONST"
          - "-Wno-MULTIDRIVEN"
          - "-Wno-IMPLICIT"
          - "-Wno-PINCONNECTEMPTY"
          - "-Wno-BLKANDNBLK"
          - "-Wno-DECLFILENAME"
          - "-Wno-PINMISSING"
          - "-Wno-WIDTH"
          - "-Wno-SELRANGE"
          - "-Wno-WIDTHCONCAT"
          - "-Wno-VARHIDDEN"
          - "-Wno-LATCH"
          - "-Wno-SYMRSVDWORD"
          - "-Wno-CASEINCOMPLETE"
          - "-Wno-UNSIGNED"
          - "-Wno-UNDRIVEN"
          - "-Wno-UNUSEDPARAM"
          - "-Wno-UNUSEDSIGNAL"
          - "-Wno-ALWCOMBORDER"
          - "-Wno-IMPORTSTAR"
          - "-Wno-ENUMVALUE"
          - "-Wno-LITENDIAN"
          - "-Wno-UNOPTFLAT"
          - "-Wno-SYNCASYNCNET"
          - "-Wno-BLKSEQ"
          - "-Wno-LITENDIAN"
          - "-Wno-UNPACKED"
          - "-Wno-SELRANGE"
